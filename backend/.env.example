# Required
GOOGLE_API_KEY=your-gemini-api-key

# Admin panel password (defaults to "zuno-demo" if unset)
ADMIN_PASSWORD=change-me

# Storage: "local" (default) or "gcs"
STORAGE_BACKEND=local

# Only if STORAGE_BACKEND=gcs (Google Cloud Storage = the S3 equivalent):
# GCS_BUCKET=your-bucket-name
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional cross-family judge keys:
# ANTHROPIC_API_KEY=...
# OPENAI_API_KEY=...
