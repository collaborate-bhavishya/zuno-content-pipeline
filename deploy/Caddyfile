# Caddy auto-HTTPS for the backend API host AND the app's main domain.
# {$SITE_ADDRESS} = flowbackend.zunolearn.com (API + /app static fallback).
{$SITE_ADDRESS} {
    # Static frontend at /app (kept as a fallback URL).
    handle_path /app/* {
        root * /srv/app
        try_files {path} {path}/index.html
        file_server
    }
    redir /app /app/ 308

    reverse_proxy backend:8000
}

# Main app domain — served from this box after the Amplify app's build
# pipeline corrupted account-side (2026-07-22). Root-path static export.
flow.zunolearn.com {
    root * /srv/flow
    try_files {path} {path}/index.html
    file_server
}
